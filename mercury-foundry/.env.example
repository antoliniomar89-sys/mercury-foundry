# Mercury Foundry — variabili d'ambiente di esempio
#
# Copia questo file in .env e compila i valori reali (mai committare .env).
# Il file .env è in .gitignore: i segreti non devono mai finire nel repository.
#
# ---------------------------------------------------------------------------
# Selezione del provider AI
# ---------------------------------------------------------------------------

# Provider da usare. Valori accettati:
#   fake             — provider deterministico (default); zero chiamate di rete;
#                      usato per sviluppo locale, CI e test automatici.
#   openai_compatible — provider reale compatibile con l'API OpenAI (o endpoint
#                      compatibili: OpenRouter, Azure OpenAI, Groq, ecc.).
#   openai           — alias retrocompatibile per openai_compatible.
#
# Default: fake (nessuna API key richiesta, nessun costo).
MERCURY_AI_PROVIDER=fake

# ---------------------------------------------------------------------------
# Configurazione del provider reale (richiesta solo se MERCURY_AI_PROVIDER != fake)
# ---------------------------------------------------------------------------

# Chiave API. Impostare come Replit Secret, non in chiaro qui.
# MERCURY_AI_API_KEY=

# Modello da usare (es. gpt-4o, gpt-4o-mini, claude-3-5-sonnet, ecc.)
# MERCURY_AI_MODEL=gpt-4o-mini

# Base URL dell'endpoint OpenAI-compatibile.
# Per OpenAI ufficiale: https://api.openai.com/v1
# Per provider alternativi: usare il loro endpoint /v1
# MERCURY_AI_BASE_URL=https://api.openai.com/v1
#
# Alias retrocompatibile (accettato, stessa semantica):
# MERCURY_AI_API_BASE_URL=https://api.openai.com/v1

# Timeout in secondi per ogni singola chiamata al provider.
# MERCURY_AI_TIMEOUT_SECONDS=30

# Numero massimo di chiamate al provider per singola run (budget chiamate).
# MERCURY_AI_MAX_CALLS_PER_RUN=10

# Numero massimo di token (input + output) consumabili per singola run.
# MERCURY_AI_MAX_TOKENS_PER_RUN=50000

# Costo stimato massimo in USD per singola run (budget economico).
# MERCURY_AI_MAX_COST_USD_PER_RUN=0.50

# Costo stimato per 1000 token in USD (opzionale; se omesso, il costo stimato
# non viene calcolato né registrato).
# MERCURY_AI_COST_PER_1K_TOKENS_USD=0.00015

# ---------------------------------------------------------------------------
# Limiti e comportamento del loop di esecuzione
# ---------------------------------------------------------------------------

# Numero massimo di tentativi automatici per task (default: 3).
# MERCURY_FOUNDRY_MAX_ATTEMPTS=3

# ---------------------------------------------------------------------------
# Approvazione umana (gate di sicurezza)
# ---------------------------------------------------------------------------

# Abilitare il gate di approvazione umana interattivo (default: false).
# Richiede un terminale interattivo e la variabile MERCURY_HUMAN_APPROVAL_SECRET.
# MERCURY_HUMAN_APPROVAL_ENABLED=false

# Segreto per il challenge di approvazione (impostare come Replit Secret).
# MERCURY_HUMAN_APPROVAL_SECRET=

# ---------------------------------------------------------------------------
# Feature flags (tutti disabilitati per default in V0)
# ---------------------------------------------------------------------------

# Verifica adattiva: seleziona i test in base ai file modificati (default: true).
# MERCURY_ADAPTIVE_VERIFICATION_ENABLED=true

# Modalità Autonomy Boundary Layer: shadow (registra) o enforced (blocca).
# MERCURY_AUTONOMY_MODE=shadow

# Modalità Constitutional Core: disabled, shadow (default) o enforce.
# MERCURY_CONSTITUTIONAL_CORE_MODE=shadow

# Replication: activation e provisioning sono forbidden in V0.
# MERCURY_REPLICATION_ACTIVATION_ENABLED=false
# MERCURY_REPLICATION_PROVISIONING_ENABLED=false

# Economic Outcome: scale automatico e aumento budget disabilitati in V0.
# MERCURY_OUTCOME_AUTO_SCALE_ENABLED=false
# MERCURY_OUTCOME_AUTO_BUDGET_INCREASE_ENABLED=false
